#!/usr/bin/env bash
# demo — OPULUX / Tesla88 Production 部署工具
#
#   ./demo update            推荐：完整生产部署（官方命令）
#   ./demo update --force    强制重建所有服务
#   ./demo                   向后兼容（等同于 update）
#   ./demo --force           向后兼容（等同于 update --force）
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILE="$SCRIPT_DIR/docker-compose.production.yml"
DC="docker compose -f $COMPOSE_FILE"

# ── 颜色 ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓  ${NC}$*"; }
fail() { echo -e "${RED}  ✗  ${NC}$*" >&2; }
info() { echo -e "${BLUE}  →  ${NC}$*"; }
warn() { echo -e "${YELLOW}  ⚠  ${NC}$*"; }
step() { echo -e "\n${BOLD}${CYAN}━━━ $* ━━━${NC}"; }

# ── 状态追踪（部署历史用）──────────────────────────────────────────────────────
DEPLOY_START=$(date +%s)
DEPLOY_RESULT="RUNNING"
DEPLOY_FAIL_REASON=""
APPLIED_MIGRATIONS="(none)"
BUILD_SUMMARY="(no rebuild)"
DEPLOYED_COMMIT="unknown"
HISTORY_DIR="$SCRIPT_DIR/deploy_history"
HISTORY_FILE=""
MIGRATE_LOG="/tmp/deploy-migrate-$$.log"
trap 'rm -f "$MIGRATE_LOG" "$ROLLBACK_FILE"' EXIT

# ── 回滚机制 ──────────────────────────────────────────────────────────────────
ROLLBACK_TAG="rollback-$(date +%Y%m%d%H%M%S)"
ROLLBACK_FILE="/tmp/deploy-rollback-$$.txt"
NEED_ROLLBACK=false
: > "$ROLLBACK_FILE"

save_image_for_rollback() {
    local svc="$1"
    local cid
    cid=$($DC ps -q "$svc" 2>/dev/null | head -1) || return 0
    [ -z "$cid" ] && return 0
    local img_id
    img_id=$(docker inspect --format '{{.Image}}' "$cid" 2>/dev/null) || return 0
    [ -z "$img_id" ] && return 0
    local tag
    tag=$(docker inspect --format '{{index .RepoTags 0}}' "$img_id" 2>/dev/null) || return 0
    [ -z "$tag" ] && return 0
    local base="${tag%%:*}"
    if docker tag "$tag" "${base}:${ROLLBACK_TAG}" 2>/dev/null; then
        echo "${svc}:${base}" >> "$ROLLBACK_FILE"
        info "  已保存 ${svc} 回滚镜像"
    fi
}

do_rollback() {
    [ "$NEED_ROLLBACK" != "true" ] && return 0
    [ ! -s "$ROLLBACK_FILE" ] && return 0
    warn "══ 开始回滚到部署前版本 ══"
    while IFS= read -r entry; do
        local svc="${entry%%:*}"
        local base="${entry#*:}"
        local rimg="${base}:${ROLLBACK_TAG}"
        if docker image inspect "$rimg" >/dev/null 2>&1; then
            docker tag "$rimg" "${base}:latest" 2>/dev/null || true
            warn "  → ${svc} 已回滚"
        fi
    done < "$ROLLBACK_FILE"
    $DC up -d erp website telegram-bot 2>/dev/null || warn "回滚启动失败，请手动执行: $DC up -d"
    warn "Docker 已回滚"
}

# ── 部署历史 ──────────────────────────────────────────────────────────────────
write_deploy_history() {
    local result="$1" reason="${2:-}"
    mkdir -p "$HISTORY_DIR"
    HISTORY_FILE="${HISTORY_DIR}/$(date +%Y%m%d-%H%M%S).log"
    local duration=$(( $(date +%s) - DEPLOY_START ))
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    local operator
    operator="$(whoami)@$(hostname -s 2>/dev/null || echo host)"
    cat > "$HISTORY_FILE" <<EOF
================================================
OPULUX Deployment Log
================================================
Timestamp   : $(date '+%Y-%m-%d %H:%M:%S')
Version     : ${APP_VERSION:-v1.0.0}
Branch      : ${branch}
Commit      : ${DEPLOYED_COMMIT}
Operator    : ${operator}
Result      : ${result}

Applied Migrations:
  ${APPLIED_MIGRATIONS}

Services Rebuilt:
  ${BUILD_SUMMARY}

Deployment Duration:
  ${duration}s

$([ -n "$reason" ] && echo "Failure Reason:
  ${reason}" || true)
================================================
EOF
    ok "部署历史已保存: deploy_history/$(basename "$HISTORY_FILE")"
}

die() {
    local msg="$1"
    DEPLOY_RESULT="FAILED"
    DEPLOY_FAIL_REASON="$msg"
    echo ""
    echo -e "${RED}${BOLD}  ✗  FAILED: ${msg}${NC}" >&2
    echo -e "${RED}     停止部署，请检查上方日志。${NC}" >&2
    echo ""
    do_rollback
    write_deploy_history "FAILED" "$msg"
    # 提示数据库还原（不自动执行，太危险）
    local latest_backup
    latest_backup=$(ls -t "$SCRIPT_DIR/backups"/memberbot_*.sql.gz 2>/dev/null | head -1 || echo "")
    if [ -n "$latest_backup" ]; then
        echo ""
        echo -e "${YELLOW}  数据库还原命令（如需要）：${NC}"
        echo -e "  ${CYAN}docker exec -i \$(docker compose -f $COMPOSE_FILE ps -q postgres) psql -U \$POSTGRES_USER -d \$POSTGRES_DB < <(zcat $(basename "$latest_backup"))${NC}"
        echo ""
    fi
    exit 1
}

# ── 工具函数 ──────────────────────────────────────────────────────────────────
env_val() {
    grep -E "^${1}=" "$SCRIPT_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2- | sed "s/^['\"]//; s/['\"]$//"
}

wait_for_healthy() {
    local svc="$1" max="${2:-240}" label="${3:-$1}"
    local elapsed=0 cid="" health=""
    info "等待 ${label} healthy..."
    while [ $elapsed -lt $max ]; do
        cid=$($DC ps -q "$svc" 2>/dev/null | head -1)
        if [ -n "$cid" ]; then
            health=$(docker inspect --format '{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
            case "$health" in
                healthy)
                    ok "${label} ✓  (${elapsed}s)"
                    return 0
                    ;;
                unhealthy)
                    fail "${label} 进入 unhealthy 状态"
                    echo "=== ${label} 日志（最后 100 行）==="
                    $DC logs "$svc" 2>/dev/null | tail -100
                    return 1
                    ;;
            esac
        fi
        sleep 5; elapsed=$((elapsed + 5))
    done
    fail "${label} 健康检查超时（${max}s）"
    [ -n "$cid" ] && $DC logs "$svc" 2>/dev/null | tail -100
    return 1
}

check_http() {
    local url="$1" label="${2:-$1}" code
    code=$(curl -sk -o /dev/null -w "%{http_code}" \
           --connect-timeout 10 --max-time 15 "$url" 2>/dev/null || echo "000")
    if echo "$code" | grep -qE "^(2|3)"; then
        ok "${label}  HTTP ${code}"; return 0
    fi
    fail "${label}  HTTP ${code}"; return 1
}

# ════════════════════════════════════════════════════════════════════════════
# cmd_update — 完整生产部署流程
# ════════════════════════════════════════════════════════════════════════════
cmd_update() {

# ── 结果追踪 ─────────────────────────────────────────────────────────────────
R_POSTGRES=FAIL; R_REDIS=WARN; R_ERP=FAIL
R_WEBSITE=FAIL;  R_BOT=WARN;   R_NGINX=FAIL
R_HTTP_W=FAIL;   R_HTTP_E=FAIL
T_BUILD=0; T_MIGRATE=0; T_HEALTH=0

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║   OPULUX SYSTEM — Production Deployment      ║${NC}"
echo -e "${BOLD}${CYAN}║   $(date '+%Y-%m-%d %H:%M:%S')                    ║${NC}"
if [ "${FORCE:-false}" = "true" ]; then
echo -e "${BOLD}${CYAN}║   Mode: --force (rebuild all)                ║${NC}"
fi
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${NC}"
echo ""

# ════════════════════════════════════════════════════════════════════════════
# Step 1  当前版本信息
# ════════════════════════════════════════════════════════════════════════════
step "Step 1  当前版本信息"
GIT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
GIT_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
GIT_COMMIT_FULL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
GIT_DATE=$(git log -1 --format="%ci" 2>/dev/null || echo "unknown")
echo -e "  ${BOLD}Current Branch ${NC}: ${GIT_BRANCH}"
echo -e "  ${BOLD}Current Commit ${NC}: ${GIT_COMMIT}  (${GIT_DATE})"
echo -e "  ${BOLD}Deploy Target  ${NC}: origin/main"
DEPLOYED_COMMIT="$GIT_COMMIT"

# ════════════════════════════════════════════════════════════════════════════
# Step 2  Git 状态检查 + 拉取最新代码
# ════════════════════════════════════════════════════════════════════════════
step "Step 2  Git 状态检查 & 更新"

# 脏仓库检测
DIRTY=false
if ! git diff --quiet 2>/dev/null; then DIRTY=true; fi
if ! git diff --cached --quiet 2>/dev/null; then DIRTY=true; fi

if [ "$DIRTY" = "true" ]; then
    if [ "${FORCE:-false}" = "true" ]; then
        warn "本地仓库有未提交的修改（--force 模式，忽略继续）"
    else
        fail "本地仓库有未提交的修改（dirty working tree）"
        git status --short 2>/dev/null | head -10
        die "请先提交或 stash 本地修改，或使用 --force 继续"
    fi
fi

LOCAL="$GIT_COMMIT_FULL"
BUILD_ERP=false
BUILD_WEBSITE=false
BUILD_BOT=false
NEED_BUILD=false

info "Fetching origin..."
if git fetch origin main --quiet 2>/dev/null; then
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "$LOCAL")
    if [ "$LOCAL" != "$REMOTE" ]; then
        warn "发现新版本：${LOCAL:0:7}  →  ${REMOTE:0:7}"

        # 分析变更文件（pull 前）
        CHANGED=$(git diff --name-only "$LOCAL" "$REMOTE" 2>/dev/null || echo "")
        CHANGED_COUNT=$(echo "$CHANGED" | grep -c . 2>/dev/null || echo "0")
        info "变更文件：${CHANGED_COUNT} 个"
        echo "$CHANGED" | head -15 | while IFS= read -r f; do [ -n "$f" ] && info "  • $f"; done

        # 服务变更检测
        if echo "$CHANGED" | grep -qE "^erp/(src|components|app|lib|public|Dockerfile)"; then
            BUILD_ERP=true
        fi
        if echo "$CHANGED" | grep -qE "^erp/migrations/"; then
            BUILD_ERP=true
        fi
        if echo "$CHANGED" | grep -qE "^website/"; then
            BUILD_WEBSITE=true
        fi
        if echo "$CHANGED" | grep -qE "^(src/|Dockerfile$|package\.json$|bot\.py|bot\.js)"; then
            BUILD_BOT=true
        fi

        info "拉取最新代码..."
        git pull origin main || die "git pull 失败"
        DEPLOYED_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
        ok "代码已更新 → ${DEPLOYED_COMMIT}"

        if [ "$BUILD_ERP" = "true" ] || [ "$BUILD_WEBSITE" = "true" ] || [ "$BUILD_BOT" = "true" ]; then
            NEED_BUILD=true
            [ "$BUILD_ERP"     = "true" ] && info "  → ERP 需要重建"
            [ "$BUILD_WEBSITE" = "true" ] && info "  → Website 需要重建"
            [ "$BUILD_BOT"     = "true" ] && info "  → Telegram Bot 需要重建"
        else
            ok "仅配置/迁移文件变更，无需重建镜像"
        fi
    else
        ok "已是最新版本（${LOCAL:0:7}），继续部署..."
    fi
else
    warn "无法连接 GitHub（离线模式），跳过版本检查"
fi

if [ "${FORCE:-false}" = "true" ]; then
    warn "--force：强制重建所有服务"
    BUILD_ERP=true; BUILD_WEBSITE=true; BUILD_BOT=true; NEED_BUILD=true
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 3  环境验证
# ════════════════════════════════════════════════════════════════════════════
step "Step 3  环境验证"

# Docker
command -v docker >/dev/null 2>&1        || die "Docker 未安装"
docker info >/dev/null 2>&1              || die "Docker daemon 未运行"
docker compose version >/dev/null 2>&1   || die "需要 Docker Compose V2"
ok "Docker Engine + Compose V2 ✓"

# Git
command -v git >/dev/null 2>&1           || die "Git 未安装"
ok "Git ✓"

# 网络（可选）
if curl -sf --connect-timeout 5 https://hub.docker.com >/dev/null 2>&1; then
    ok "Internet Connection ✓"
else
    warn "无法访问 Docker Hub（离线环境，不影响部署）"
fi

# 磁盘空间
DISK_FREE_KB=$(df -k "$SCRIPT_DIR" 2>/dev/null | awk 'NR==2{print $4}' || echo "0")
DISK_FREE_GB=$(( ${DISK_FREE_KB:-0} / 1024 / 1024 ))
if [ "${DISK_FREE_GB:-0}" -lt 2 ]; then
    die "磁盘剩余空间不足（${DISK_FREE_GB}GB < 2GB，请清理后重试）"
elif [ "${DISK_FREE_GB:-0}" -lt 5 ]; then
    warn "磁盘空间偏低（${DISK_FREE_GB}GB），建议 5GB 以上"
else
    ok "磁盘空间 ${DISK_FREE_GB}GB ✓"
fi

# 内存（非致命）
FREE_MEM_MB=$(free -m 2>/dev/null | awk '/^Mem:/{print $7}' || echo "unknown")
if [ "$FREE_MEM_MB" != "unknown" ] && [ "${FREE_MEM_MB:-0}" -lt 256 ]; then
    warn "可用内存不足（${FREE_MEM_MB}MB < 256MB），系统可能不稳定"
else
    ok "可用内存 ${FREE_MEM_MB}MB ✓"
fi

# CPU
CPU_CORES=$(nproc 2>/dev/null || echo "unknown")
ok "CPU ${CPU_CORES} 核 ✓"

# .env 文件
[ -f "$SCRIPT_DIR/.env" ] || die ".env 文件不存在"
ok ".env 文件 ✓"

# 必要环境变量
REQUIRED_VARS="POSTGRES_DB POSTGRES_USER POSTGRES_PASSWORD JWT_SECRET MEMBER_JWT_SECRET BOT_TOKEN"
for _var in $REQUIRED_VARS; do
    _val=$(env_val "$_var")
    if [ -z "$_val" ]; then
        die ".env 缺少必要变量: ${_var}"
    fi
done
ok "必要环境变量 ✓  (${REQUIRED_VARS})"

# Compose 文件
[ -f "$COMPOSE_FILE" ] || die "docker-compose.production.yml 不存在"

# ════════════════════════════════════════════════════════════════════════════
# Step 4  Docker Compose 配置验证
# ════════════════════════════════════════════════════════════════════════════
step "Step 4  Docker Compose 配置验证"
$DC config --quiet 2>/dev/null || die "docker-compose.production.yml 配置无效，请检查语法"
ok "docker-compose.production.yml 配置合法 ✓"

# ════════════════════════════════════════════════════════════════════════════
# Step 5  SSL 证书（首次部署才生成）
# ════════════════════════════════════════════════════════════════════════════
step "Step 5  SSL 证书"
SSL_EXISTS=$(docker volume ls -q 2>/dev/null | grep -c "nginx_ssl" || true)
if [ "$SSL_EXISTS" = "0" ]; then
    info "首次部署，生成自签名 SSL 证书..."
    $DC run --rm certgen || die "SSL 证书生成失败"
    ok "SSL 证书已生成"
else
    ok "SSL Volume 已存在  →  跳过"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 6  启动基础设施（PostgreSQL + Redis）
# ════════════════════════════════════════════════════════════════════════════
step "Step 6  启动基础设施"
_t=$(date +%s)
info "启动 PostgreSQL 和 Redis..."
$DC up -d postgres redis || die "基础服务启动失败"

wait_for_healthy postgres 60  "PostgreSQL" && R_POSTGRES=PASS || die "PostgreSQL 启动失败"
wait_for_healthy redis    30  "Redis"      && R_REDIS=PASS    || { warn "Redis 启动异常（继续）"; R_REDIS=WARN; }
ok "基础设施就绪（$(( $(date +%s) - _t ))s）"

# ════════════════════════════════════════════════════════════════════════════
# Step 7  数据库备份（Migration 之前）
# ════════════════════════════════════════════════════════════════════════════
step "Step 7  数据库备份"
BACKUP_DIR="$SCRIPT_DIR/backups"
mkdir -p "$BACKUP_DIR"
PG_CID=$($DC ps -q postgres 2>/dev/null | head -1)
BACKUP_FILE=""

if [ -n "$PG_CID" ]; then
    BACKUP_FILE="${BACKUP_DIR}/memberbot_$(date +%Y%m%d_%H%M).sql.gz"
    PG_USER=$(env_val POSTGRES_USER)
    PG_DB=$(env_val POSTGRES_DB)
    info "创建数据库备份: $(basename "$BACKUP_FILE")"
    if docker exec "$PG_CID" pg_dump -U "$PG_USER" -d "$PG_DB" 2>/dev/null \
            | gzip > "$BACKUP_FILE"; then
        BACKUP_SIZE=$(du -sh "$BACKUP_FILE" 2>/dev/null | cut -f1 || echo "?")
        ok "备份完成: $(basename "$BACKUP_FILE")  (${BACKUP_SIZE})"
        # 保留最近 10 个备份，清理旧的
        ls -t "${BACKUP_DIR}"/memberbot_*.sql.gz 2>/dev/null | tail -n +11 | xargs rm -f 2>/dev/null || true
    else
        rm -f "$BACKUP_FILE"
        die "数据库备份失败，中止部署（保护数据安全）"
    fi
else
    warn "PostgreSQL 容器未运行，跳过备份（首次部署）"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 8  Database Migration（幂等，已应用的自动跳过）
# ════════════════════════════════════════════════════════════════════════════
step "Step 8  Database Migration"
_t=$(date +%s)
info "运行 Migration（已应用的自动跳过）..."
$DC run --rm migrate 2>&1 | tee "$MIGRATE_LOG" || { die "Migration 失败"; }

# 解析已应用的 migration
APPLIED_MIGRATIONS=$(grep "-> 执行:" "$MIGRATE_LOG" 2>/dev/null \
    | sed 's/.*-> 执行: //' | tr '\n' ',' | sed 's/,$//' || echo "none")
[ -z "$APPLIED_MIGRATIONS" ] && APPLIED_MIGRATIONS="(all up-to-date)"

T_MIGRATE=$(( $(date +%s) - _t ))
ok "Migration 完成（${T_MIGRATE}s）  应用: ${APPLIED_MIGRATIONS}"

# ════════════════════════════════════════════════════════════════════════════
# Step 9  保存回滚镜像 + 选择性 Build
# ════════════════════════════════════════════════════════════════════════════
step "Step 9  Build & 部署"
_t=$(date +%s)

if [ "$NEED_BUILD" = "true" ]; then
    # 保存当前运行镜像用于回滚
    info "保存回滚镜像..."
    for _svc in erp website telegram-bot; do
        save_image_for_rollback "$_svc"
    done
    NEED_ROLLBACK=true

    # 构建变更的服务
    BUILD_SVC_LIST=""
    if [ "$BUILD_ERP"     = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST erp"; fi
    if [ "$BUILD_WEBSITE" = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST website"; fi
    if [ "$BUILD_BOT"     = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST telegram-bot"; fi
    BUILD_SVC_LIST="${BUILD_SVC_LIST# }"

    info "构建服务: ${BUILD_SVC_LIST}"
    # shellcheck disable=SC2086
    $DC build --parallel $BUILD_SVC_LIST || die "Docker Build 失败"
    ok "Build 完成"
    BUILD_SUMMARY="$BUILD_SVC_LIST"

    # 重启变更的服务（--no-deps 不重启 postgres/redis）
    # shellcheck disable=SC2086
    $DC up -d --no-deps $BUILD_SVC_LIST || die "应用服务启动失败"
    $DC up -d nginx || die "Nginx 启动失败"
else
    info "无需重建，确保所有服务正在运行..."
    $DC up -d erp website telegram-bot nginx || die "服务启动失败"
fi

T_BUILD=$(( $(date +%s) - _t ))
ok "服务启动完成（${T_BUILD}s）"

# ════════════════════════════════════════════════════════════════════════════
# Step 10  服务健康检查
# ════════════════════════════════════════════════════════════════════════════
step "Step 10  服务健康检查"
_t=$(date +%s)

wait_for_healthy erp          240 "ERP"           && R_ERP=PASS     || die "ERP unhealthy"
wait_for_healthy website      240 "Website"       && R_WEBSITE=PASS || die "Website unhealthy"
wait_for_healthy telegram-bot 120 "Telegram Bot"  && R_BOT=PASS    \
    || { warn "Telegram Bot 异常（请检查 BOT_TOKEN）"; R_BOT=WARN; }
wait_for_healthy nginx         60 "Nginx"         && R_NGINX=PASS   || die "Nginx unhealthy"

# Nginx 重载（清除 upstream DNS 缓存，确保新容器 IP 生效）
info "重载 Nginx 配置（清除 upstream DNS 缓存）..."
if $DC exec nginx nginx -s reload >/dev/null 2>&1; then
    ok "Nginx 已重载 ✓"
else
    warn "nginx reload 失败，尝试重启..."
    $DC restart nginx || warn "Nginx restart 失败，继续"
    sleep 3
fi

T_HEALTH=$(( $(date +%s) - _t ))

# ════════════════════════════════════════════════════════════════════════════
# Step 11  内部健康检查（容器网络连通）
# ════════════════════════════════════════════════════════════════════════════
step "Step 11  内部健康检查"
NGINX_CID=$($DC ps -q nginx 2>/dev/null | head -1)
if [ -n "$NGINX_CID" ]; then
    docker exec "$NGINX_CID" wget -qO- --timeout=10 http://erp:3000/api/ping >/dev/null 2>&1 \
        && ok "容器网络: ERP ✓" \
        || die "ERP 容器不可达（进程未监听 3000 端口）"

    docker exec "$NGINX_CID" wget -qO- --timeout=10 http://website:3000/api/ping >/dev/null 2>&1 \
        && ok "容器网络: Website ✓" \
        || die "Website 容器不可达（进程未监听 3000 端口）"
else
    die "Nginx 容器未找到"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 12  公网端点验证
# ════════════════════════════════════════════════════════════════════════════
step "Step 12  公网端点验证"
check_http "https://apidemo.club"           "Website  →  https://apidemo.club"           && R_HTTP_W=PASS || true
check_http "https://erp.apidemo.club/login" "ERP      →  https://erp.apidemo.club/login" && R_HTTP_E=PASS || true

if [ "$R_HTTP_W" != "PASS" ] || [ "$R_HTTP_E" != "PASS" ]; then
    die "公网端点验证失败（请检查 DNS 和 Cloudflare）"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 13  上线后 60 秒监控（检测启动后崩溃）
# ════════════════════════════════════════════════════════════════════════════
step "Step 13  上线后 60 秒监控"
ERP_CID=$($DC ps -q erp 2>/dev/null | head -1)

if [ -n "$ERP_CID" ]; then
    FIRST_OK=false; CONSEC_FAIL=0; MONITOR_FAIL=false
    for i in $(seq 1 60); do
        if docker exec "$ERP_CID" \
               wget -qO /dev/null --timeout=3 http://127.0.0.1:3000/api/ping >/dev/null 2>&1; then
            [ "$FIRST_OK" = "false" ] && { ok "ERP 首次内部健康确认（${i}s）"; FIRST_OK=true; }
            CONSEC_FAIL=0
        else
            CONSEC_FAIL=$((CONSEC_FAIL + 1))
            if [ "$FIRST_OK" = "true" ] && [ "$CONSEC_FAIL" -ge 2 ]; then
                echo "─── ERP 日志（最后 100 行）───"
                $DC logs --tail=100 --no-log-prefix erp 2>&1 || true
                MONITOR_FAIL=true; break
            fi
        fi
        sleep 1
    done
    if [ "$MONITOR_FAIL" = "true" ]; then
        die "ERP 在上线后崩溃（诊断已输出至上方日志）"
    elif [ "$FIRST_OK" = "true" ]; then
        ok "60 秒监控完成 — ERP 持续稳定 ✓"
    else
        warn "60 秒内 ERP 未通过 ping（可能仍在预热），跳过"
    fi
else
    warn "无法取得 ERP 容器 ID，跳过监控"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 14  Docker 清理（移除悬空镜像 + 构建缓存）
# ════════════════════════════════════════════════════════════════════════════
step "Step 14  Docker 清理"
PRUNED_IMG=$(docker image prune -f 2>/dev/null | grep "reclaimed" | grep -oE "[0-9.]+ [KMGT]?B" || echo "0B")
ok "悬空镜像已清理  回收: ${PRUNED_IMG}"
docker builder prune -f --keep-storage 2GB >/dev/null 2>&1 || true
ok "构建缓存已整理（保留 2GB）"

# ════════════════════════════════════════════════════════════════════════════
# Step 15  生成部署历史 + 最终摘要
# ════════════════════════════════════════════════════════════════════════════
step "Step 15  部署历史"
DEPLOY_RESULT="SUCCESS"
write_deploy_history "SUCCESS"

# 最终 Banner
TOTAL=$(( $(date +%s) - DEPLOY_START ))

_r() {
    case "$2" in
        PASS) echo -e "  ${GREEN}✓${NC}  $1" ;;
        WARN) echo -e "  ${YELLOW}⚠${NC}  $1" ;;
        *)    echo -e "  ${RED}✗${NC}  $1" ;;
    esac
}

echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║           OPULUX SYSTEM Deployment Summary       ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${BOLD}Version        ${NC}${APP_VERSION:-v1.0.0}"
echo -e "  ${BOLD}Branch         ${NC}${GIT_BRANCH}"
echo -e "  ${BOLD}Commit         ${NC}${DEPLOYED_COMMIT}"
echo -e "  ${BOLD}Applied Migration ${NC}${APPLIED_MIGRATIONS}"
echo -e "  ${BOLD}Services Rebuilt  ${NC}${BUILD_SUMMARY}"
echo ""
_r "Website          " "$R_WEBSITE"
_r "ERP              " "$R_ERP"
_r "Telegram Bot     " "$R_BOT"
_r "PostgreSQL       " "$R_POSTGRES"
_r "Redis            " "$R_REDIS"
_r "Website URL      " "$R_HTTP_W"
_r "ERP URL          " "$R_HTTP_E"
echo ""
printf "  ${BOLD}Deployment Duration${NC}  Build %-5ss  Migration %-5ss  Health %-5ss  Total %ss\n" \
    "$T_BUILD" "$T_MIGRATE" "$T_HEALTH" "$TOTAL"
echo ""
echo -e "  ${BOLD}Website${NC}  https://apidemo.club"
echo -e "  ${BOLD}ERP    ${NC}  https://erp.apidemo.club"
[ -n "$BACKUP_FILE" ] && echo -e "  ${BOLD}Backup ${NC}  backups/$(basename "$BACKUP_FILE")"
[ -n "$HISTORY_FILE" ] && echo -e "  ${BOLD}Log    ${NC}  deploy_history/$(basename "$HISTORY_FILE")"
echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║              Deployment Complete ✓               ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════════╝${NC}"
echo ""

} # end cmd_update

# ════════════════════════════════════════════════════════════════════════════
# 入口 — 解析子命令
# ════════════════════════════════════════════════════════════════════════════
FORCE=false
SUBCMD=""

for _a in "$@"; do
    case "$_a" in
        update)     SUBCMD="update" ;;
        --force|-f) FORCE=true ;;
        --help|-h)
            echo "用法: ./demo [update] [--force]"
            echo ""
            echo "  ./demo update          推荐：完整生产部署（官方命令）"
            echo "  ./demo update --force  强制重建所有服务"
            echo "  ./demo                 向后兼容（等同于 update）"
            exit 0
            ;;
        *)
            echo "未知参数: $_a  (运行 ./demo --help 查看帮助)" >&2
            exit 1
            ;;
    esac
done

[ -z "$SUBCMD" ] && SUBCMD="update"  # 无参数时默认 update（向后兼容）

export FORCE

case "$SUBCMD" in
    update) cmd_update ;;
esac
