#!/usr/bin/env bash
# demo — Tesla88 / SSWIN88 Production 智能启动
#
# 用法:
#   ./demo           自动判断：有更新 → 拉取+构建+迁移+重启；无更新 → 直接启动
#   ./demo --force   强制重新构建（不管是否有更新）
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILE="$SCRIPT_DIR/docker-compose.production.yml"
DC="docker compose -f $COMPOSE_FILE"

FORCE=false
for _a in "$@"; do [ "$_a" = "--force" ] && FORCE=true; done

# ── 颜色 ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'
ok()   { echo -e "${GREEN}  ✓  ${NC}$*"; }
fail() { echo -e "${RED}  ✗  ${NC}$*" >&2; }
info() { echo -e "${BLUE}  →  ${NC}$*"; }
warn() { echo -e "${YELLOW}  ⚠  ${NC}$*"; }
step() { echo -e "\n${BOLD}${CYAN}━━━ $* ━━━${NC}"; }
die()  { fail "$*"; exit 1; }

rl() {  # result_line label result
    case "$2" in
        PASS) echo -e "  ${GREEN}✓  PASS${NC}  $1" ;;
        WARN) echo -e "  ${YELLOW}⚠  WARN${NC}  $1" ;;
        *)    echo -e "  ${RED}✗  FAIL${NC}  $1" ;;
    esac
}

START=$(date +%s)

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║   Tesla88 / SSWIN88  Production      ║${NC}"
echo -e "${BOLD}${CYAN}║   $(date '+%Y-%m-%d %H:%M:%S')              ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════╝${NC}"
echo ""

# ── 结果变量 ─────────────────────────────────────────────────────────────────
R_POSTGRES=FAIL; R_REDIS=WARN; R_ERP=FAIL; R_WEBSITE=FAIL
R_BOT=WARN;      R_NGINX=FAIL; R_HTTP=FAIL
T_BUILD=0; T_MIGRATE=0; T_HEALTH=0

# ════════════════════════════════════════════════════════════════════════════
# wait_for_migrate — 等待 one-shot migrate 容器完成
# ════════════════════════════════════════════════════════════════════════════
wait_for_migrate() {
    local max=300 elapsed=0 cid="" state="" code=""
    info "等待 Migration 完成..."
    while [ $elapsed -lt $max ]; do
        cid=$(docker ps -a --filter "label=com.docker.compose.service=migrate" \
              --format "{{.ID}}" 2>/dev/null | head -1)
        if [ -n "$cid" ]; then
            local raw
            raw=$(docker inspect --format '{{.State.Status}}|{{.State.ExitCode}}' "$cid" 2>/dev/null || echo "?|?")
            state="${raw%|*}"; code="${raw#*|}"
            case "$state" in
                exited)
                    if [ "$code" = "0" ]; then ok "Migration 完成（${elapsed}s）"; return 0; fi
                    fail "Migration 失败（ExitCode=${code}）"
                    docker logs "$cid" 2>&1 | tail -30
                    return 1
                    ;;
                running) ;;
            esac
        fi
        sleep 3; elapsed=$((elapsed + 3))
    done
    fail "Migration 超时（${max}s）"; return 1
}

# ════════════════════════════════════════════════════════════════════════════
# wait_for_healthy — 等待服务进入 healthy 状态
# ════════════════════════════════════════════════════════════════════════════
wait_for_healthy() {
    local svc="$1" max="${2:-240}" elapsed=0 cid="" health=""
    info "等待 ${svc} healthy..."
    while [ $elapsed -lt $max ]; do
        cid=$($DC ps -q "$svc" 2>/dev/null | head -1)
        if [ -n "$cid" ]; then
            health=$(docker inspect --format '{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
            case "$health" in
                healthy)   ok "${svc} ✓ (${elapsed}s)"; return 0 ;;
                unhealthy) fail "${svc} unhealthy"; $DC logs "$svc" 2>/dev/null | tail -20; return 1 ;;
            esac
        fi
        sleep 5; elapsed=$((elapsed + 5))
    done
    fail "${svc} 超时（${max}s）"; return 1
}

# ════════════════════════════════════════════════════════════════════════════
# check_http — 检查公网 URL 返回 2xx/3xx
# ════════════════════════════════════════════════════════════════════════════
check_http() {
    local url="$1" label="${2:-$1}" code
    code=$(curl -sk -o /dev/null -w "%{http_code}" --connect-timeout 10 --max-time 15 "$url" 2>/dev/null || echo "000")
    if echo "$code" | grep -qE "^(2|3)"; then
        ok "${label}  HTTP ${code}"; return 0
    fi
    fail "${label}  HTTP ${code}"; return 1
}

# ════════════════════════════════════════════════════════════════════════════
# 1. 环境检查
# ════════════════════════════════════════════════════════════════════════════
step "1  环境检查"
command -v docker >/dev/null 2>&1      || die "Docker 未安装"
docker info >/dev/null 2>&1            || die "Docker daemon 未运行"
docker compose version >/dev/null 2>&1 || die "Docker Compose V2 未安装"
[ -f "$SCRIPT_DIR/.env" ]              || die ".env 不存在，请先创建"
[ -f "$COMPOSE_FILE" ]                 || die "docker-compose.production.yml 不存在"
ok "Docker ✓  |  .env ✓  |  Compose 文件 ✓"

# ════════════════════════════════════════════════════════════════════════════
# 2. 检查是否有新 Commit（决定是否 Build）
# ════════════════════════════════════════════════════════════════════════════
step "2  检查 GitHub 更新"

LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
info "当前 Commit: ${LOCAL:0:7}"

NEED_BUILD=false
if git fetch origin main --quiet 2>/dev/null; then
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "")
    if [ -n "$REMOTE" ] && [ "$LOCAL" != "$REMOTE" ]; then
        warn "发现新版本：${LOCAL:0:7} → ${REMOTE:0:7}"
        info "自动拉取最新代码..."
        git pull origin main
        AFTER=$(git rev-parse HEAD 2>/dev/null)
        ok "已更新：${LOCAL:0:7} → ${AFTER:0:7}"
        git diff --name-only "$LOCAL" HEAD 2>/dev/null | head -10 | while read -r f; do info "  • $f"; done
        NEED_BUILD=true
    else
        ok "已是最新版本（${LOCAL:0:7}）"
    fi
else
    warn "无法连接 GitHub（离线模式）"
fi

if [ "$FORCE" = "true" ]; then
    warn "--force 标志：强制重新 Build"
    NEED_BUILD=true
fi

# ════════════════════════════════════════════════════════════════════════════
# 3. SSL 证书（首次部署才生成）
# ════════════════════════════════════════════════════════════════════════════
step "3  SSL 证书"
SSL_EXISTS=$(docker volume ls -q 2>/dev/null | grep -c "nginx_ssl" || true)
if [ "$SSL_EXISTS" = "0" ]; then
    info "首次部署，生成自签名 SSL 证书..."
    $DC run --rm certgen
    ok "SSL 证书已生成"
else
    ok "SSL Volume 已存在，跳过"
fi

# ════════════════════════════════════════════════════════════════════════════
# 4. Build & 启动
# ════════════════════════════════════════════════════════════════════════════
step "4  Build & 启动"
_t=$(date +%s)
if [ "$NEED_BUILD" = "true" ]; then
    info "重新构建镜像（有更新）..."
    $DC build --parallel
    ok "Build 完成"
    info "重启全部服务..."
    $DC up -d
else
    info "无更新，直接启动（跳过 Build）..."
    $DC up -d
fi
T_BUILD=$(( $(date +%s) - _t ))
ok "Compose Up 完成（${T_BUILD}s）"

# ════════════════════════════════════════════════════════════════════════════
# 5. Migration（仅在有更新或首次启动时真正执行，但 container 每次都会 run）
# ════════════════════════════════════════════════════════════════════════════
step "5  Database Migration"
_t=$(date +%s)
wait_for_migrate || die "Migration 失败，停止"
T_MIGRATE=$(( $(date +%s) - _t ))

# ════════════════════════════════════════════════════════════════════════════
# 6. 服务健康检查
# ════════════════════════════════════════════════════════════════════════════
step "6  服务健康检查"
_t=$(date +%s)

wait_for_healthy postgres    60  && R_POSTGRES=PASS || die "PostgreSQL unhealthy，停止"
wait_for_healthy redis       60  && R_REDIS=PASS    || warn "Redis unhealthy（继续）"
wait_for_healthy erp        240  && R_ERP=PASS      || { $DC logs erp 2>/dev/null | tail -20; die "ERP unhealthy，停止"; }
wait_for_healthy website    240  && R_WEBSITE=PASS  || { $DC logs website 2>/dev/null | tail -20; die "Website unhealthy，停止"; }
wait_for_healthy telegram-bot 120 && R_BOT=PASS     || warn "Telegram Bot unhealthy（请检查 BOT_TOKEN）"
wait_for_healthy nginx       60  && R_NGINX=PASS    || warn "Nginx unhealthy"

T_HEALTH=$(( $(date +%s) - _t ))

# ════════════════════════════════════════════════════════════════════════════
# 7. 内部连通测试（Nginx → 后端）
# ════════════════════════════════════════════════════════════════════════════
step "7  内部连通测试"
NGINX_CID=$($DC ps -q nginx 2>/dev/null | head -1)
if [ -n "$NGINX_CID" ]; then
    docker exec "$NGINX_CID" wget -qO- --timeout=10 http://erp:3000/login     >/dev/null 2>&1 \
        && ok "Nginx → ERP ✓" || die "Nginx → ERP 失败，停止"
    docker exec "$NGINX_CID" wget -qO- --timeout=10 http://website:3000        >/dev/null 2>&1 \
        && ok "Nginx → Website ✓" || die "Nginx → Website 失败，停止"
else
    warn "Nginx 容器未找到，跳过内部测试"
fi

# ════════════════════════════════════════════════════════════════════════════
# 8. 公网 HTTP 检查
# ════════════════════════════════════════════════════════════════════════════
step "8  公网 HTTP 检查"
HTTP_ALL_OK=true
check_http "https://apidemo.club"           "Website" || HTTP_ALL_OK=false
check_http "https://erp.apidemo.club/login" "ERP"     || HTTP_ALL_OK=false
[ "$HTTP_ALL_OK" = "true" ] && R_HTTP=PASS

# ════════════════════════════════════════════════════════════════════════════
# 最终 Banner
# ════════════════════════════════════════════════════════════════════════════
TOTAL=$(( $(date +%s) - START ))
GIT_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")

echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║       Production Ready               ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════╝${NC}"
echo ""
rl "PostgreSQL"   "$R_POSTGRES"
rl "Redis"        "$R_REDIS"
rl "ERP"          "$R_ERP"
rl "Website"      "$R_WEBSITE"
rl "Telegram Bot" "$R_BOT"
rl "Nginx"        "$R_NGINX"
echo ""
rl "HTTP Check"   "$R_HTTP"
echo ""
echo -e "${BOLD}  URL：${NC}"
echo -e "    Website  →  https://apidemo.club"
echo -e "    ERP      →  https://erp.apidemo.club"
echo ""
echo -e "${BOLD}  耗时：${NC}"
printf "    %-16s %ss\n" "Build & Up"  "$T_BUILD"
printf "    %-16s %ss\n" "Migration"   "$T_MIGRATE"
printf "    %-16s %ss\n" "Health"      "$T_HEALTH"
printf "    %-16s %ss\n" "Total"       "$TOTAL"
echo ""
echo -e "${BOLD}  版本：${NC}  Commit ${GIT_COMMIT}  |  $(date '+%Y-%m-%d %H:%M:%S')"
echo ""
echo -e "${BOLD}${GREEN}  ✓  Deployment Finished Successfully${NC}"
echo ""

[ "$R_HTTP" = "PASS" ] && exit 0 || exit 1
