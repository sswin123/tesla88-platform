#!/usr/bin/env bash
# demo — Tesla88 / SSWIN88 Production 智能部署
#
#   ./demo          检测变更 → 选择性 Build + Migration + 重启；无变更 → 启动 + Migration
#   ./demo --force  强制重建所有服务
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILE="$SCRIPT_DIR/docker-compose.production.yml"
DC="docker compose -f $COMPOSE_FILE"

FORCE=false
for _a in "$@"; do [ "$_a" = "--force" ] && FORCE=true; done

# ── 颜色 ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "${GREEN}  ✓  ${NC}$*"; }
fail() { echo -e "${RED}  ✗  ${NC}$*" >&2; }
info() { echo -e "${BLUE}  →  ${NC}$*"; }
warn() { echo -e "${YELLOW}  ⚠  ${NC}$*"; }
step() { echo -e "\n${BOLD}${CYAN}━━━ $* ━━━${NC}"; }

# ── 回滚机制 ──────────────────────────────────────────────────────────────────
ROLLBACK_TAG="rollback-$(date +%Y%m%d%H%M%S)"
ROLLBACK_FILE="/tmp/deploy-rollback-$$.txt"
NEED_ROLLBACK=false
: > "$ROLLBACK_FILE"  # 创建空文件
trap 'rm -f "$ROLLBACK_FILE"' EXIT

save_image_for_rollback() {
    local svc="$1"
    local cid
    cid=$($DC ps -q "$svc" 2>/dev/null | head -1) || return 0
    [ -z "$cid" ] && return 0
    local img_id
    img_id=$(docker inspect --format '{{.Image}}' "$cid" 2>/dev/null) || return 0
    [ -z "$img_id" ] && return 0
    local tag
    tag=$(docker inspect --format '{{index .RepoTags 0}}' "$img_id" 2>/dev/null) || return 0
    [ -z "$tag" ] && return 0
    local base="${tag%%:*}"
    if docker tag "$tag" "${base}:${ROLLBACK_TAG}" 2>/dev/null; then
        echo "${svc}:${base}" >> "$ROLLBACK_FILE"
        info "  已保存 ${svc} 回滚镜像"
    fi
}

rollback() {
    [ "$NEED_ROLLBACK" != "true" ] && return 0
    [ ! -s "$ROLLBACK_FILE" ] && return 0
    warn "══ 开始回滚到部署前版本 ══"
    while IFS= read -r entry; do
        local svc="${entry%%:*}"
        local base="${entry#*:}"
        local rimg="${base}:${ROLLBACK_TAG}"
        if docker image inspect "$rimg" >/dev/null 2>&1; then
            docker tag "$rimg" "${base}:latest" 2>/dev/null || true
            warn "  → ${svc} 已回滚"
        fi
    done < "$ROLLBACK_FILE"
    $DC up -d erp website telegram-bot 2>/dev/null || warn "回滚启动失败，请手动执行: $DC up -d"
    warn "回滚完成（注意：Migration 无法自动回滚，请手动检查数据库）"
}

die() {
    echo ""
    echo -e "${RED}${BOLD}  ✗  FAILED: $1${NC}" >&2
    echo -e "${RED}     停止部署，请检查上方日志。${NC}" >&2
    echo ""
    rollback
    exit 1
}

START=$(date +%s)

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║    Tesla88 / SSWIN88  Production Deploy  ║${NC}"
echo -e "${BOLD}${CYAN}║    $(date '+%Y-%m-%d %H:%M:%S')                ║${NC}"
if [ "$FORCE" = "true" ]; then
echo -e "${BOLD}${CYAN}║    Mode: --force                         ║${NC}"
fi
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════╝${NC}"
echo ""

# ── 结果追踪 ─────────────────────────────────────────────────────────────────
R_POSTGRES=FAIL; R_REDIS=WARN; R_ERP=FAIL
R_WEBSITE=FAIL;  R_BOT=WARN;   R_NGINX=FAIL
R_HTTP_W=FAIL;   R_HTTP_E=FAIL
T_BUILD=0; T_MIGRATE=0; T_HEALTH=0
BUILD_SUMMARY="(无重建)"

# ════════════════════════════════════════════════════════════════════════════
# wait_for_healthy — 等待服务进入 healthy 状态
# ════════════════════════════════════════════════════════════════════════════
wait_for_healthy() {
    local svc="$1" max="${2:-240}" label="${3:-$1}"
    local elapsed=0 cid="" health=""
    info "等待 ${label} healthy..."
    while [ $elapsed -lt $max ]; do
        cid=$($DC ps -q "$svc" 2>/dev/null | head -1)
        if [ -n "$cid" ]; then
            health=$(docker inspect --format '{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
            case "$health" in
                healthy)
                    ok "${label} ✓  (${elapsed}s)"
                    return 0
                    ;;
                unhealthy)
                    fail "${label} 进入 unhealthy 状态"
                    echo ""
                    echo "=== ${label} 日志（最后 200 行）==="
                    $DC logs "$svc" 2>/dev/null | tail -200
                    return 1
                    ;;
            esac
        fi
        sleep 5; elapsed=$((elapsed + 5))
    done
    fail "${label} 健康检查超时（${max}s）"
    [ -n "$cid" ] && { echo "=== ${label} 日志（最后 100 行）==="; $DC logs "$svc" 2>/dev/null | tail -100; }
    return 1
}

# ════════════════════════════════════════════════════════════════════════════
# check_http — 检查公网 URL 返回 2xx/3xx
# ════════════════════════════════════════════════════════════════════════════
check_http() {
    local url="$1" label="${2:-$1}" code
    code=$(curl -sk -o /dev/null -w "%{http_code}" \
           --connect-timeout 10 --max-time 15 "$url" 2>/dev/null || echo "000")
    if echo "$code" | grep -qE "^(2|3)"; then
        ok "${label}  HTTP ${code}"; return 0
    fi
    fail "${label}  HTTP ${code}"; return 1
}

# ════════════════════════════════════════════════════════════════════════════
# Step 1  环境检查
# ════════════════════════════════════════════════════════════════════════════
step "Step 1  环境检查"
command -v docker >/dev/null 2>&1      || die "Docker 未安装"
docker info >/dev/null 2>&1            || die "Docker daemon 未运行"
docker compose version >/dev/null 2>&1 || die "需要 Docker Compose V2"
[ -f "$SCRIPT_DIR/.env" ]              || die ".env 文件不存在，请先创建"
[ -f "$COMPOSE_FILE" ]                 || die "docker-compose.production.yml 不存在"
ok "Docker  ✓    .env  ✓    Compose 文件  ✓"

# ════════════════════════════════════════════════════════════════════════════
# Step 2  检查 GitHub 更新 + 检测变更服务
# ════════════════════════════════════════════════════════════════════════════
step "Step 2  检查 GitHub 更新"

LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
info "当前版本：${LOCAL:0:7}"

BUILD_ERP=false
BUILD_WEBSITE=false
BUILD_BOT=false
NEED_BUILD=false

if git fetch origin main --quiet 2>/dev/null; then
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "$LOCAL")
    if [ "$LOCAL" != "$REMOTE" ]; then
        warn "发现新版本：${LOCAL:0:7}  →  ${REMOTE:0:7}"

        # 分析变更文件（pull 前，用于选择性构建决策）
        CHANGED=$(git diff --name-only "$LOCAL" "$REMOTE" 2>/dev/null || echo "")
        CHANGED_COUNT=$(echo "$CHANGED" | grep -c . 2>/dev/null || echo "0")
        info "变更文件：${CHANGED_COUNT} 个"
        echo "$CHANGED" | head -15 | while IFS= read -r f; do [ -n "$f" ] && info "  • $f"; done

        # 服务变更检测
        if echo "$CHANGED" | grep -qE "^erp/(src|components|app|lib|public|Dockerfile)"; then
            BUILD_ERP=true
        fi
        if echo "$CHANGED" | grep -qE "^erp/migrations/"; then
            BUILD_ERP=true  # Migration 变更 → ERP 服务也需要感知（依赖 migrate 完成）
        fi
        if echo "$CHANGED" | grep -qE "^website/"; then
            BUILD_WEBSITE=true
        fi
        if echo "$CHANGED" | grep -qE "^(src/|Dockerfile$|package\.json$|bot\.py|bot\.js)"; then
            BUILD_BOT=true
        fi

        info "拉取最新代码..."
        git pull origin main
        AFTER=$(git rev-parse HEAD 2>/dev/null)
        ok "代码已更新：${LOCAL:0:7}  →  ${AFTER:0:7}"

        if [ "$BUILD_ERP" = "true" ] || [ "$BUILD_WEBSITE" = "true" ] || [ "$BUILD_BOT" = "true" ]; then
            NEED_BUILD=true
            [ "$BUILD_ERP"     = "true" ] && info "  → ERP 需要重建"
            [ "$BUILD_WEBSITE" = "true" ] && info "  → Website 需要重建"
            [ "$BUILD_BOT"     = "true" ] && info "  → Telegram Bot 需要重建"
        else
            ok "配置/迁移文件变更，无需重建服务镜像"
        fi
    else
        ok "已是最新版本（${LOCAL:0:7}）"
    fi
else
    warn "无法连接 GitHub（离线模式），跳过版本检查"
fi

if [ "$FORCE" = "true" ]; then
    warn "--force：强制重建所有服务"
    BUILD_ERP=true; BUILD_WEBSITE=true; BUILD_BOT=true; NEED_BUILD=true
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 3  SSL 证书（首次部署才生成）
# ════════════════════════════════════════════════════════════════════════════
step "Step 3  SSL 证书"
SSL_EXISTS=$(docker volume ls -q 2>/dev/null | grep -c "nginx_ssl" || true)
if [ "$SSL_EXISTS" = "0" ]; then
    info "首次部署，生成自签名 SSL 证书..."
    $DC run --rm certgen || die "SSL 证书生成失败"
    ok "SSL 证书已生成"
else
    ok "SSL Volume 已存在  →  跳过"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 4  启动基础服务（数据库先就绪）
# ════════════════════════════════════════════════════════════════════════════
step "Step 4  启动基础服务"
_t=$(date +%s)

info "启动 PostgreSQL 和 Redis..."
$DC up -d postgres redis || die "基础服务启动失败"

wait_for_healthy postgres 60 "PostgreSQL" && R_POSTGRES=PASS || die "PostgreSQL 启动失败"
wait_for_healthy redis    30 "Redis"      && R_REDIS=PASS    || { warn "Redis 启动异常（继续）"; R_REDIS=WARN; }

ok "基础服务就绪（$(( $(date +%s) - _t ))s）"

# ════════════════════════════════════════════════════════════════════════════
# Step 5  Database Migration（每次都运行，幂等——已应用的自动跳过）
# ════════════════════════════════════════════════════════════════════════════
step "Step 5  Database Migration"
_t=$(date +%s)
info "运行 Migration（docker-migrate.sh，已应用的自动跳过）..."
$DC run --rm migrate || die "Migration 失败"
T_MIGRATE=$(( $(date +%s) - _t ))
ok "Migration 完成（${T_MIGRATE}s）"

# ════════════════════════════════════════════════════════════════════════════
# Step 6  选择性 Build & 启动应用服务
# ════════════════════════════════════════════════════════════════════════════
step "Step 6  Build & 启动"
_t=$(date +%s)

if [ "$NEED_BUILD" = "true" ]; then
    # 保存当前运行镜像用于失败回滚
    info "保存回滚镜像..."
    for _svc in erp website telegram-bot; do
        save_image_for_rollback "$_svc"
    done
    NEED_ROLLBACK=true

    # 选择性构建：只重建有变更的服务
    BUILD_SVC_LIST=""
    if [ "$BUILD_ERP"     = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST erp"; fi
    if [ "$BUILD_WEBSITE" = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST website"; fi
    if [ "$BUILD_BOT"     = "true" ]; then BUILD_SVC_LIST="$BUILD_SVC_LIST telegram-bot"; fi
    BUILD_SVC_LIST="${BUILD_SVC_LIST# }"  # 去掉前导空格

    info "构建服务: ${BUILD_SVC_LIST}"
    # shellcheck disable=SC2086
    $DC build --parallel $BUILD_SVC_LIST || die "Docker Build 失败"
    ok "Build 完成"

    BUILD_SUMMARY="${BUILD_SVC_LIST}"

    # 启动/重启变更的服务（--no-deps 避免重建 postgres/redis）
    # shellcheck disable=SC2086
    $DC up -d --no-deps $BUILD_SVC_LIST || die "应用服务启动失败"
    $DC up -d nginx || die "Nginx 启动失败"
else
    info "无需重建，确保所有服务正在运行..."
    $DC up -d erp website telegram-bot nginx || die "服务启动失败"
fi

T_BUILD=$(( $(date +%s) - _t ))
ok "服务启动完成（${T_BUILD}s）"

# ════════════════════════════════════════════════════════════════════════════
# Step 7  服务健康检查
# ════════════════════════════════════════════════════════════════════════════
step "Step 7  服务健康检查"
_t=$(date +%s)

wait_for_healthy erp          240 "ERP"           && R_ERP=PASS     || die "ERP unhealthy"
wait_for_healthy website      240 "Website"       && R_WEBSITE=PASS || die "Website unhealthy"
wait_for_healthy telegram-bot 120 "Telegram Bot"  && R_BOT=PASS    \
    || { warn "Telegram Bot 异常（请检查 BOT_TOKEN）"; R_BOT=WARN; }
wait_for_healthy nginx         60 "Nginx"         && R_NGINX=PASS   || die "Nginx unhealthy"

# Nginx 重载（清除 upstream DNS 缓存，使新容器 IP 生效）
info "重载 Nginx 配置（清除 upstream DNS 缓存）..."
if $DC exec nginx nginx -s reload >/dev/null 2>&1; then
    ok "Nginx 已重载 ✓"
else
    warn "nginx reload 失败，尝试重启容器..."
    $DC restart nginx || warn "Nginx restart 也失败，继续（Step 9 公网测试将验证）"
    sleep 3
fi

T_HEALTH=$(( $(date +%s) - _t ))

# ════════════════════════════════════════════════════════════════════════════
# Step 8  容器网络连通测试
# ════════════════════════════════════════════════════════════════════════════
step "Step 8  容器网络连通测试"
NGINX_CID=$($DC ps -q nginx 2>/dev/null | head -1)
if [ -n "$NGINX_CID" ]; then
    docker exec "$NGINX_CID" \
        wget -qO- --timeout=10 http://erp:3000/api/ping >/dev/null 2>&1 \
        && ok "容器网络: ERP 3000 可达 ✓" \
        || die "ERP 容器不可达（进程未监听 3000 端口）"

    docker exec "$NGINX_CID" \
        wget -qO- --timeout=10 http://website:3000/api/ping >/dev/null 2>&1 \
        && ok "容器网络: Website 3000 可达 ✓" \
        || die "Website 容器不可达（进程未监听 3000 端口）"
else
    die "Nginx 容器未找到，无法执行内部测试"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 9  公网 HTTP 检查
# ════════════════════════════════════════════════════════════════════════════
step "Step 9  公网 HTTP 检查"
check_http "https://apidemo.club"           "Website  →  https://apidemo.club"           && R_HTTP_W=PASS || true
check_http "https://erp.apidemo.club/login" "ERP      →  https://erp.apidemo.club/login" && R_HTTP_E=PASS || true

if [ "$R_HTTP_W" != "PASS" ] || [ "$R_HTTP_E" != "PASS" ]; then
    die "公网 HTTP 检查未全部通过（请检查 DNS 和 Cloudflare）"
fi

# ════════════════════════════════════════════════════════════════════════════
# Step 10  上线后 60 秒实时监控
# ════════════════════════════════════════════════════════════════════════════
step "Step 10  上线后 60 秒实时监控"
ERP_CID=$($DC ps -q erp 2>/dev/null | head -1)

dump_erp_diag() {
    local when="$1"
    warn "ERP 在上线后 ${when}s 出现故障！抓取诊断..."
    echo ""
    echo "─────────── docker logs erp (last 100 lines) ───────────"
    $DC logs --tail=100 --no-log-prefix erp 2>&1 || true
    echo ""
    echo "─────────── docker inspect erp (State + Health) ───────────"
    docker inspect --format '{{json .State}}' "$ERP_CID" 2>/dev/null \
        | python3 -m json.tool 2>/dev/null \
        || docker inspect "$ERP_CID" 2>/dev/null \
        || echo "(无法 inspect)"
    echo ""
    echo "─────────── docker inspect Health.Log ───────────"
    docker inspect --format '{{json .State.Health.Log}}' "$ERP_CID" 2>/dev/null \
        | python3 -m json.tool 2>/dev/null || true
}

if [ -n "$ERP_CID" ]; then
    FIRST_OK=false
    CONSEC_FAIL=0
    MONITOR_FAIL=false

    for i in $(seq 1 60); do
        if docker exec "$ERP_CID" \
               wget -qO /dev/null --timeout=3 http://127.0.0.1:3000/api/ping >/dev/null 2>&1; then
            if [ "$FIRST_OK" = "false" ]; then
                ok "ERP 首次内部健康确认（${i}s）"
                FIRST_OK=true
            fi
            CONSEC_FAIL=0
        else
            CONSEC_FAIL=$((CONSEC_FAIL + 1))
            if [ "$FIRST_OK" = "true" ] && [ "$CONSEC_FAIL" -ge 2 ]; then
                dump_erp_diag "$i"
                MONITOR_FAIL=true
                break
            fi
        fi
        sleep 1
    done

    if [ "$MONITOR_FAIL" = "true" ]; then
        die "ERP 在上线后发生故障（诊断已输出至上方日志）"
    elif [ "$FIRST_OK" = "true" ]; then
        ok "60 秒监控完成 — ERP 持续稳定 ✓"
    else
        warn "60 秒内 ERP 未通过内部 ping（容器可能仍在预热），跳过监控"
    fi
else
    warn "无法取得 ERP 容器 ID，跳过 60 秒监控"
fi

# ════════════════════════════════════════════════════════════════════════════
# 最终 Banner
# ════════════════════════════════════════════════════════════════════════════
TOTAL=$(( $(date +%s) - START ))
GIT_COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")

_r() {
    case "$2" in
        PASS) echo -e "  ${GREEN}✓  PASS${NC}    $1" ;;
        WARN) echo -e "  ${YELLOW}⚠  WARN${NC}    $1" ;;
        *)    echo -e "  ${RED}✗  FAIL${NC}    $1" ;;
    esac
}

echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║          Production  Ready               ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""
_r "PostgreSQL"    "$R_POSTGRES"
_r "Redis"         "$R_REDIS"
_r "ERP"           "$R_ERP"
_r "Website"       "$R_WEBSITE"
_r "Telegram Bot"  "$R_BOT"
_r "Nginx"         "$R_NGINX"
echo ""
_r "HTTP  Website" "$R_HTTP_W"
_r "HTTP  ERP"     "$R_HTTP_E"
echo ""
echo -e "  ──────────────────────────────────────────"
echo ""
echo -e "  ${BOLD}Website${NC}"
echo -e "    https://apidemo.club"
echo ""
echo -e "  ${BOLD}ERP${NC}"
echo -e "    https://erp.apidemo.club"
echo ""
echo -e "  ${BOLD}Version${NC}"
echo -e "    ${GIT_COMMIT}"
echo ""
echo -e "  ${BOLD}Services Rebuilt${NC}"
echo -e "    ${BUILD_SUMMARY}"
echo ""
echo -e "  ${BOLD}Deployment Time${NC}"
printf "    Build %-6ss   Migration %-6ss   Health %-6ss   Total %ss\n" \
    "$T_BUILD" "$T_MIGRATE" "$T_HEALTH" "$TOTAL"
echo ""
echo -e "  ──────────────────────────────────────────"
echo ""
echo -e "  ${BOLD}Quick Commands${NC}"
echo -e "    ${CYAN}./demo${NC}          智能部署（自动检测变更）"
echo -e "    ${CYAN}./demo --force${NC}  强制重建所有服务"
echo -e "    ${CYAN}./stop${NC}          停止（保留数据）"
echo -e "    ${CYAN}./status${NC}        查看系统状态"
echo ""
echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${GREEN}║          Production  Ready               ║${NC}"
echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════╝${NC}"
echo ""
