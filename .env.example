# ════════════════════════════════════════════════════════════════════
# Root environment — single source of truth for all services.
#
# Usage:
#   cp .env.example .env
#   # Fill in every value marked YOUR_… / change-this… below
#   ./scripts/update-system.sh
#
# DO NOT manually edit erp/.env or website/.env — they are
# auto-generated from this file by scripts/gen-env.sh.
# ════════════════════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────
BOT_TOKEN=your_bot_token_here
SUPER_ADMIN_ID=your_telegram_user_id_here

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=member_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── ERP Admin Panel ───────────────────────────────────
# Random 64-char string: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-64-char-string

# ── Website Member Portal ─────────────────────────────
# Random 64-char string — MUST differ from JWT_SECRET
MEMBER_JWT_SECRET=change-this-to-a-random-64-char-string

# ── Domain Settings ───────────────────────────────────
# Public-facing URLs (used by ERP health check + cross-service pings)
# Example: https://admin.yourdomain.com
ERP_URL=http://localhost:3001
# Example: https://www.yourdomain.com
WEBSITE_URL=http://localhost:3002

# ── Business Logic ────────────────────────────────────
CS_USERNAME=your_cs_username
ACCOUNT_CHANGE_COOLDOWN_HOURS=24

# ── Telegram Groups ───────────────────────────────────
# Finance Group: receives deposit / withdrawal review notifications
ADMIN_CHAT_ID=-1001234567890
# Support Group: receives Live Chat / CS notifications
SUPPORT_CHAT_ID=-1001234567890

# ── Bot Relay Server ──────────────────────────────────
BOT_RELAY_AUTH_TOKEN=change_me_relay_token
BOT_RELAY_PORT=8090

# ── Limits (RM) ───────────────────────────────────────
MIN_DEPOSIT_AMOUNT=30
MIN_WITHDRAWAL_AMOUNT=50

# ── Backup ────────────────────────────────────────────
# Host path for ERP database backups (maps to /backups inside container)
# Leave blank to use Docker-managed volume (erp_backups)
BACKUP_DIR=

# ── Release ───────────────────────────────────────────
APP_VERSION=1.0.0
