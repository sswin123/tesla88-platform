# ── Bot ──────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
SUPER_ADMIN_ID=your_telegram_user_id_here

# ── PostgreSQL ────────────────────────────────────────
# Docker Compose 内固定使用 db（服务名）
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=member_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Business Logic ────────────────────────────────────
# 客服 Telegram 用户名（不含 @）
CS_USERNAME=your_cs_username

# 更换游戏账号冷却时间（小时）
ACCOUNT_CHANGE_COOLDOWN_HOURS=24
