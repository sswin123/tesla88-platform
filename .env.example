# ── Bot ──────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
SUPER_ADMIN_ID=your_telegram_user_id_here

# ── PostgreSQL ────────────────────────────────────────
# Docker Compose 内固定使用 db（服务名）
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=member_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Business Logic ────────────────────────────────────
# 客服 Telegram 用户名（不含 @）
CS_USERNAME=your_cs_username

# 更换游戏账号冷却时间（小时）
ACCOUNT_CHANGE_COOLDOWN_HOURS=24

# ── Phase 2: Groups ───────────────────────────────────
# Finance Group：接收 💰 充值 / 💸 提款 审核通知
ADMIN_CHAT_ID=-1001234567890

# Support Group：接收 💬 Live Chat / 客服通知（Phase 3）
SUPPORT_CHAT_ID=-1001234567890

# ── Phase 3: Bot Relay Server ────────────────────────
BOT_RELAY_AUTH_TOKEN=change_me_relay_token
BOT_RELAY_PORT=8090

# ── Phase 2: Limits ───────────────────────────────────
# 最低充值金额（RM）
MIN_DEPOSIT_AMOUNT=30

# 最低提款金额（RM）
MIN_WITHDRAWAL_AMOUNT=50
