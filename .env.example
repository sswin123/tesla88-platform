# ════════════════════════════════════════════════════════════════════
# Root environment — single source of truth for all services.
#
# Usage:
#   cp .env.example .env
#   nano .env          ← fill in every REPLACE_WITH_… value
#   docker compose -f docker-compose.production.yml up -d
#
# ── What goes where ──────────────────────────────────────────────────
# docker-compose.production.yml reads variables directly from this file.
# Internal service URLs (DB host, ERP internal URL, bot relay URL) are
# hardcoded inside docker-compose.production.yml using Docker service
# names — do NOT add them here.
#
# dev usage (scripts/gen-env.sh generates erp/.env and website/.env):
#   ./scripts/update-system.sh
# ════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────
# NOTE: In production, the DB host is the Docker service name "postgres".
#       It is hardcoded in docker-compose.production.yml — do NOT add
#       POSTGRES_HOST here for production.
POSTGRES_DB=member_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# ── ERP Admin Panel JWT ───────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_SECURE_64CHAR_HEX

# ── Website Member Portal JWT ─────────────────────────────────────────
# MUST be different from JWT_SECRET
# Generate: openssl rand -hex 32
MEMBER_JWT_SECRET=REPLACE_WITH_DIFFERENT_64CHAR_HEX

# ── Public Website URL ────────────────────────────────────────────────
# Production: https://apidemo.club
# Development: http://localhost:3002
SITE_URL=https://apidemo.club

# ── Telegram Bot ──────────────────────────────────────────────────────
# Get from @BotFather → /mybots → your bot → API Token
BOT_TOKEN=REPLACE_WITH_BOT_TOKEN

# ── Telegram Super Admin ──────────────────────────────────────────────
# Your personal Telegram user ID — get from @userinfobot
SUPER_ADMIN_ID=REPLACE_WITH_YOUR_TELEGRAM_USER_ID

# ── Telegram Group Chat IDs ───────────────────────────────────────────
# Finance/deposit group: add bot to group → send /id → copy negative number
ADMIN_CHAT_ID=REPLACE_WITH_FINANCE_GROUP_CHAT_ID
# CS/support group: add bot to group → send /id → copy negative number
SUPPORT_CHAT_ID=REPLACE_WITH_SUPPORT_GROUP_CHAT_ID

# ── CS Account ────────────────────────────────────────────────────────
# Username of the Customer Service staff account in the Telegram bot
CS_USERNAME=REPLACE_WITH_CS_USERNAME

# ── Bot Relay Auth Token ──────────────────────────────────────────────
# Shared secret between the Python bot and ERP/Website
# Generate: openssl rand -hex 24
BOT_RELAY_AUTH_TOKEN=REPLACE_WITH_RELAY_TOKEN

# ── Optional (safe defaults) ──────────────────────────────────────────
ACCOUNT_CHANGE_COOLDOWN_HOURS=24
MIN_DEPOSIT_AMOUNT=30
MIN_WITHDRAWAL_AMOUNT=50
APP_VERSION=1.0.0

# ── Dev only (not used by docker-compose.production.yml) ─────────────
# Used by scripts/gen-env.sh when running in development mode
# POSTGRES_HOST=db
# ERP_URL=http://localhost:3001
# API_URL=http://localhost:3001
# BOT_RELAY_PORT=8090
# BACKUP_DIR=
