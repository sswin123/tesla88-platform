# DO NOT edit this file manually.
# It is regenerated by scripts/gen-env.sh on every deployment.
# To change a value, edit the ROOT .env and re-run:
#   ./scripts/update-system.sh
#
# For local development (without Docker):
#   Use DB_HOST=localhost and point to your local PostgreSQL.
# ════════════════════════════════════════════════════════════════════
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=member_bot
DB_USER=postgres
DB_PASSWORD=changeme
MEMBER_JWT_SECRET=change-this-to-a-random-64-char-string
