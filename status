#!/usr/bin/env bash
# status — Tesla88 / SSWIN88 生产状态一览
#
# 用法: ./status
#
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILE="$SCRIPT_DIR/docker-compose.production.yml"
DC="docker compose -f $COMPOSE_FILE"

# ── 颜色 ──────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

pass()  { echo -e "  ${GREEN}✓  PASS${NC}  $*"; }
fail()  { echo -e "  ${RED}✗  FAIL${NC}  $*"; }
warn()  { echo -e "  ${YELLOW}⚠  WARN${NC}  $*"; }
info()  { echo -e "  ${BLUE}·  ${NC}$*"; }
label() { printf "  ${BOLD}%-18s${NC}" "$1"; }

check_http() {
    local url="$1"
    local code
    code=$(curl -sk -o /dev/null -w "%{http_code}" --connect-timeout 8 --max-time 12 "$url" 2>/dev/null || echo "000")
    echo "$code"
}

container_status() {
    local svc="$1"
    local cid health state
    cid=$($DC ps -q "$svc" 2>/dev/null | head -1)
    if [ -z "$cid" ]; then echo "not running"; return; fi
    state=$(docker inspect --format '{{.State.Status}}' "$cid" 2>/dev/null || echo "unknown")
    health=$(docker inspect --format '{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
    if [ "$health" = "none" ] || [ -z "$health" ]; then
        echo "$state"
    else
        echo "${state} (${health})"
    fi
}

echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║   Tesla88 / SSWIN88  Status          ║${NC}"
echo -e "${BOLD}${CYAN}║   $(date '+%Y-%m-%d %H:%M:%S')              ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════╝${NC}"

# ════════════════════════════════════════════════════════════════════════════
# Git 版本比较
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  Git 版本${NC}"

LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
LOCAL_SHORT="${LOCAL:0:7}"
LOCAL_MSG=$(git log -1 --pretty="%s" 2>/dev/null || echo "")

label "当前 Commit"; echo "${LOCAL_SHORT}  ${LOCAL_MSG}"

# 尝试获取远程最新
if git fetch origin main --quiet 2>/dev/null; then
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "")
    REMOTE_SHORT="${REMOTE:0:7}"
    label "GitHub Commit"; echo "$REMOTE_SHORT"
    if [ "$LOCAL" = "$REMOTE" ]; then
        label "更新状态"; echo -e "${GREEN}✓ 已是最新${NC}"
    else
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
        label "更新状态"; echo -e "${YELLOW}⚠ 落后 ${BEHIND} 个 Commit${NC}  （运行 ./demo 更新）"
    fi
else
    label "GitHub Commit"; echo "（无法连接 GitHub）"
fi

# ════════════════════════════════════════════════════════════════════════════
# Container 状态
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  Container 状态${NC}"

ALL_HEALTHY=true
for svc in postgres redis erp website telegram-bot nginx; do
    ST=$(container_status "$svc")
    label "$svc"
    case "$ST" in
        *healthy*)    echo -e "${GREEN}${ST}${NC}" ;;
        *running*)    echo -e "${YELLOW}${ST}${NC}"; ALL_HEALTHY=false ;;
        "not running") echo -e "${RED}${ST}${NC}";  ALL_HEALTHY=false ;;
        *)            echo -e "${YELLOW}${ST}${NC}"; ALL_HEALTHY=false ;;
    esac
done

# ════════════════════════════════════════════════════════════════════════════
# Migration 版本
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  Migration${NC}"

PG_CID=$($DC ps -q postgres 2>/dev/null | head -1)
if [ -n "$PG_CID" ]; then
    # 从 .env 读取 DB 参数
    PGUSER=$(grep "^POSTGRES_USER=" "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "postgres")
    PGDB=$(grep "^POSTGRES_DB=" "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "tesla88")
    PGPWD=$(grep "^POSTGRES_PASSWORD=" "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")

    LATEST_MIG=$(PGPASSWORD="$PGPWD" docker exec -e PGPASSWORD="$PGPWD" "$PG_CID" \
        psql -U "$PGUSER" -d "$PGDB" -t -c \
        "SELECT filename FROM schema_migrations ORDER BY filename DESC LIMIT 1;" \
        2>/dev/null | tr -d ' \n' || echo "unknown")

    MIG_COUNT=$(PGPASSWORD="$PGPWD" docker exec -e PGPASSWORD="$PGPWD" "$PG_CID" \
        psql -U "$PGUSER" -d "$PGDB" -t -c \
        "SELECT COUNT(*) FROM schema_migrations;" \
        2>/dev/null | tr -d ' \n' || echo "?")

    label "最新 Migration"; echo "${LATEST_MIG:-unknown}"
    label "总计 Migrations"; echo "${MIG_COUNT}"
else
    label "Migration"; echo -e "${RED}PostgreSQL 未运行${NC}"
fi

# ════════════════════════════════════════════════════════════════════════════
# HTTP 状态
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  公网 HTTP${NC}"

W_CODE=$(check_http "https://apidemo.club")
E_CODE=$(check_http "https://erp.apidemo.club/login")

label "Website"
echo "$W_CODE" | grep -qE "^(2|3)" \
    && echo -e "${GREEN}HTTP ${W_CODE}  ✓${NC}" \
    || echo -e "${RED}HTTP ${W_CODE}  ✗${NC}"

label "ERP"
echo "$E_CODE" | grep -qE "^(2|3)" \
    && echo -e "${GREEN}HTTP ${E_CODE}  ✓${NC}" \
    || echo -e "${RED}HTTP ${E_CODE}  ✗${NC}"

# ════════════════════════════════════════════════════════════════════════════
# 总结
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  操作指南${NC}"
echo -e "    启动 / 更新  →  ${BOLD}./demo${NC}"
echo -e "    停止         →  ${BOLD}./stop${NC}"
echo -e "    状态         →  ${BOLD}./status${NC}"
echo ""

if [ "$ALL_HEALTHY" = "true" ] \
   && echo "$W_CODE" | grep -qE "^(2|3)" \
   && echo "$E_CODE" | grep -qE "^(2|3)"; then
    echo -e "${BOLD}${GREEN}  ✓  Production Ready${NC}"
else
    echo -e "${BOLD}${YELLOW}  ⚠  部分服务异常，运行 ./demo 修复${NC}"
fi
echo ""
