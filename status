#!/usr/bin/env bash
# status — Tesla88 / SSWIN88 生产状态一览
#
#   ./status
#
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

COMPOSE_FILE="$SCRIPT_DIR/docker-compose.production.yml"
DC="docker compose -f $COMPOSE_FILE"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── 辅助函数 ──────────────────────────────────────────────────────────────────
lbl() { printf "  ${BOLD}%-22s${NC}" "$1:"; }

svc_status() {
    local svc="$1"
    local cid health state
    cid=$($DC ps -q "$svc" 2>/dev/null | head -1)
    [ -z "$cid" ] && { echo -e "${RED}not running${NC}"; return; }
    state=$(docker inspect --format '{{.State.Status}}'        "$cid" 2>/dev/null || echo "unknown")
    health=$(docker inspect --format '{{.State.Health.Status}}' "$cid" 2>/dev/null || echo "none")
    if [ "$health" = "healthy" ]; then
        echo -e "${GREEN}healthy${NC}"
    elif [ "$health" = "unhealthy" ]; then
        echo -e "${RED}unhealthy${NC}"
    elif [ "$state" = "running" ]; then
        echo -e "${YELLOW}running (no healthcheck)${NC}"
    else
        echo -e "${RED}${state}${NC}"
    fi
}

check_http() {
    local url="$1"
    curl -sk -o /dev/null -w "%{http_code}" \
         --connect-timeout 8 --max-time 12 "$url" 2>/dev/null || echo "000"
}

# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}${CYAN}╔══════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}${CYAN}║      TESLA88  Production  Status             ║${NC}"
echo -e "${BOLD}${CYAN}║      $(date '+%Y-%m-%d %H:%M:%S')                    ║${NC}"
echo -e "${BOLD}${CYAN}╚══════════════════════════════════════════════╝${NC}"

# ════════════════════════════════════════════════════════════════════════════
# GitHub
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  GitHub${NC}"
echo -e "  ──────────────────────────────────────────────"

LOCAL=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
LOCAL_MSG=$(git log -1 --pretty="%s" 2>/dev/null || echo "")

lbl "Current Commit"; echo "${LOCAL:0:7}  ${LOCAL_MSG}"

if git fetch origin main --quiet 2>/dev/null; then
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "$LOCAL")
    lbl "Latest Commit"; echo "${REMOTE:0:7}"
    if [ "$LOCAL" = "$REMOTE" ]; then
        lbl "Git Status"; echo -e "${GREEN}Up To Date${NC}"
    else
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
        lbl "Git Status"; echo -e "${YELLOW}Behind ${BEHIND} commit(s)  →  run ./demo to update${NC}"
    fi
else
    lbl "Latest Commit"; echo "(cannot reach GitHub)"
    lbl "Git Status";    echo -e "${YELLOW}Offline${NC}"
fi

# ════════════════════════════════════════════════════════════════════════════
# Docker
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  Docker${NC}"
echo -e "  ──────────────────────────────────────────────"

ALL_HEALTHY=true
for svc in postgres redis erp website telegram-bot nginx; do
    lbl "$svc"
    ST=$(svc_status "$svc")
    echo "$ST"
    echo "$ST" | grep -q "healthy" || ALL_HEALTHY=false
done

# ════════════════════════════════════════════════════════════════════════════
# Migration
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  Migration${NC}"
echo -e "  ──────────────────────────────────────────────"

PG_CID=$($DC ps -q postgres 2>/dev/null | head -1)
if [ -n "$PG_CID" ]; then
    PGUSER=$(grep "^POSTGRES_USER="     "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "postgres")
    PGDB=$(grep   "^POSTGRES_DB="       "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "tesla88")
    PGPWD=$(grep  "^POSTGRES_PASSWORD=" "$SCRIPT_DIR/.env" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")

    _psql() {
        PGPASSWORD="$PGPWD" docker exec \
            -e PGPASSWORD="$PGPWD" "$PG_CID" \
            psql -U "$PGUSER" -d "$PGDB" -t -c "$1" 2>/dev/null | tr -d ' \n'
    }

    MIG_LATEST=$(_psql "SELECT filename FROM schema_migrations ORDER BY filename DESC LIMIT 1;" || echo "unknown")
    MIG_COUNT=$(_psql "SELECT COUNT(*) FROM schema_migrations;" || echo "?")

    lbl "Latest Version"; echo "${MIG_LATEST:-unknown}"
    lbl "Total Applied";  echo "${MIG_COUNT} migration(s)"

    # Seed：检查是否有 seed_* migration
    MIG_SEED=$(_psql "SELECT filename FROM schema_migrations WHERE filename LIKE '%seed%' ORDER BY filename DESC LIMIT 1;" || echo "")
    lbl "Seed Version";   echo "${MIG_SEED:-none}"
else
    lbl "Status"; echo -e "${RED}PostgreSQL not running${NC}"
fi

# ════════════════════════════════════════════════════════════════════════════
# HTTP Check
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}  HTTP Check${NC}"
echo -e "  ──────────────────────────────────────────────"

HTTP_ALL_OK=true

W_CODE=$(check_http "https://apidemo.club")
lbl "https://apidemo.club"
if echo "$W_CODE" | grep -qE "^(2|3)"; then
    echo -e "${GREEN}HTTP ${W_CODE}  PASS${NC}"
else
    echo -e "${RED}HTTP ${W_CODE}  FAIL${NC}"; HTTP_ALL_OK=false
fi

E_CODE=$(check_http "https://erp.apidemo.club/login")
lbl "https://erp.apidemo.club"
if echo "$E_CODE" | grep -qE "^(2|3)"; then
    echo -e "${GREEN}HTTP ${E_CODE}  PASS${NC}"
else
    echo -e "${RED}HTTP ${E_CODE}  FAIL${NC}"; HTTP_ALL_OK=false
fi

# ════════════════════════════════════════════════════════════════════════════
# 总结
# ════════════════════════════════════════════════════════════════════════════
echo ""
echo -e "  ──────────────────────────────────────────────"
echo -e "  ${BOLD}Quick Commands${NC}"
echo -e "    ${CYAN}./demo${NC}    启动 Demo（自动判断是否更新）"
echo -e "    ${CYAN}./stop${NC}    停止 Demo（保留全部数据）"
echo -e "    ${CYAN}./status${NC}  查看系统状态"
echo ""

if [ "$ALL_HEALTHY" = "true" ] && [ "$HTTP_ALL_OK" = "true" ]; then
    echo -e "${BOLD}${GREEN}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${GREEN}║           Production  Ready                  ║${NC}"
    echo -e "${BOLD}${GREEN}╚══════════════════════════════════════════════╝${NC}"
else
    echo -e "${BOLD}${YELLOW}╔══════════════════════════════════════════════╗${NC}"
    echo -e "${BOLD}${YELLOW}║    部分服务异常 — 运行 ./demo 修复           ║${NC}"
    echo -e "${BOLD}${YELLOW}╚══════════════════════════════════════════════╝${NC}"
fi
echo ""
