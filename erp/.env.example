# ════════════════════════════════════════════════════════════════════
# erp/.env — AUTO-GENERATED from root .env
#
# DO NOT edit this file manually.
# It is regenerated by scripts/gen-env.sh on every deployment.
# To change a value, edit the ROOT .env and re-run:
#   ./scripts/update-system.sh
#
# For local development (without Docker):
#   Use localhost instead of host.docker.internal in DATABASE_URL.
#   See erp/.env.local for a ready-to-use local dev template.
# ════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres:changeme@host.docker.internal:5432/member_bot
JWT_SECRET=change-this-to-a-random-64-char-string
TELEGRAM_BOT_TOKEN=your_bot_token_here
NODE_ENV=production
BOT_RELAY_URL=http://host.docker.internal:8090
BOT_RELAY_AUTH_TOKEN=change_me_relay_token
