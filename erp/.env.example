DATABASE_URL=postgresql://postgres:password@localhost:5432/memberbot
JWT_SECRET=change-this-to-a-random-64-char-string
TELEGRAM_BOT_TOKEN=your-bot-token-here
NODE_ENV=development
# URL of the bot relay server (use host.docker.internal when ERP runs in Docker)
BOT_RELAY_URL=http://host.docker.internal:8090
# Must match BOT_RELAY_AUTH_TOKEN in the bot's .env
BOT_RELAY_AUTH_TOKEN=change_me_relay_token
