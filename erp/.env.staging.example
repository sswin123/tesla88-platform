# ═══════════════════════════════════════════════════════════════════════════════
# ERP Staging Environment Variables
# Copy this file to .env.staging and fill in all values before deploying.
#
# Usage:
#   cp erp/.env.staging.example .env.staging
#   # Edit .env.staging with real values
#   docker compose -f docker-compose.production.yml \
#                  -f docker-compose.staging.yml \
#                  --env-file .env.staging up -d
#
# SECURITY: Never commit .env.staging — it contains real credentials.
# ═══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=member_bot_staging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
MEMBER_JWT_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_RANDOM_HEX

# ── Telegram ───────────────────────────────────────────────────────────────────
BOT_TOKEN=REPLACE_WITH_STAGING_BOT_TOKEN
SUPER_ADMIN_ID=REPLACE_WITH_YOUR_TELEGRAM_USER_ID
ADMIN_CHAT_ID=REPLACE_WITH_ADMIN_CHAT_ID
SUPPORT_CHAT_ID=REPLACE_WITH_SUPPORT_CHAT_ID
CS_USERNAME=REPLACE_WITH_CS_TELEGRAM_USERNAME

# ── Application ────────────────────────────────────────────────────────────────
BOT_RELAY_AUTH_TOKEN=REPLACE_WITH_RANDOM_SECRET
SITE_URL=https://staging.apidemo.club
APP_VERSION=1.0.0-staging
ACCOUNT_CHANGE_COOLDOWN_HOURS=1
MIN_DEPOSIT_AMOUNT=10
MIN_WITHDRAWAL_AMOUNT=20

# ── Enterprise Gaming Platform ─────────────────────────────────────────────────
# AES-256-GCM key: 32 bytes encoded as 64 hex characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHAR_KEY

# System admin user ID (ERP user that owns automated game transactions)
GAME_SYSTEM_ADMIN_ID=1

# Debug flags (set to "true" for staging, "false" for production)
ENABLE_PROVIDER_DEBUG=true
CALLBACK_DEBUG=true
RETRY_ENABLED=true
IDEMPOTENCY_ENABLED=true

# ── 918KISS Staging Credentials ────────────────────────────────────────────────
# These values are stored encrypted in the DB via gp_credentials.
# After running the seed SQL, update each credential via ERP Admin UI
# (Settings > Game Providers > 918KISS > Edit Credentials) or psql:
#
#   UPDATE gp_credentials
#   SET value = '<encrypted_value>', is_encrypted = TRUE
#   WHERE provider_id = (SELECT id FROM gp_providers WHERE code = '918KISS')
#     AND key = '<credential_key>';
#
# Credential keys to populate:
#   api_token       — provided by 918KISS operations team
#   operator_token  — secret token 918KISS sends in every callback
#   md5_key         — H5 Login signature key
#   secret_key      — H5 Login signature key
#   encrypt_key     — 8-byte DES-ECB key for H5 QS encryption
#   delimiter       — sign string delimiter (provider-assigned)
#
# To encrypt a plaintext value:
#   node -e "
#     const {createCipheriv,randomBytes}=require('crypto');
#     const key=Buffer.from(process.env.AES_ENCRYPTION_KEY,'hex');
#     const iv=randomBytes(12);
#     const c=createCipheriv('aes-256-gcm',key,iv);
#     const ct=Buffer.concat([c.update('<PLAINTEXT>','utf8'),c.final()]);
#     const tag=c.getAuthTag();
#     console.log(Buffer.concat([iv,tag,ct]).toString('base64'));
#   "
